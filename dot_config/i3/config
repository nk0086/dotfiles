set $mod Mod4

bar {
    font pango:DejaVu Sans Mono, FontAwesome 12
    position top
    status_command i3status-rs ~/.config/i3status-rust/config.toml
    colors {
        separator #666666
        background #222222
        statusline #dddddd
        focused_workspace #0088CC #0088CC #ffffff
        active_workspace #333333 #333333 #ffffff
        inactive_workspace #333333 #333333 #888888
        urgent_workspace #2f343a #900000 #ffffff
    }
}

#default_border pixel 1
for_window [class=".*"] border pixel 2
# i3-gaps settings {
set $default_inner_gaps 5
set $default_outer_gaps 5
gaps inner $default_inner_gaps
gaps outer $default_outer_gaps
# }

# application etc..
exec --no-startup-id "sh $HOME/.screenlayout/default.sh"
exec --no-startup-id "sh $HOME/.config/i3/wallpaper.sh"
exec --no-startup-id fcitx -d
exec --no-startup-id picom --config $HOME/.config/picom/picom.conf
bindsym $mod+Shift+w exec "sh $HOME/.config/i3/wallpaper.sh"
bindsym $mod+Return exec kitty
bindsym $mod+space exec rofi -modi combi -show combi
bindsym $mod+p exec gm import -trim $(date "+Pictures/screenshot/%Y%m%d-%H%M%S.png")
bindsym $mod+Shift+t exec "sh $HOME/deepl-clip/deepl-clip.sh"

# window setting {
# focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# kill focused window
bindsym $mod+q kill

# screen
bindsym $mod+f fullscreen toggle

# switch to workspace
bindsym $mod+Shift+a workspace 1; mode "default"
bindsym $mod+Shift+s workspace 2; mode "default"
bindsym $mod+Shift+d workspace 3; mode "default"
bindsym $mod+Shift+f workspace 4; mode "default"
bindsym $mod+Shift+g workspace 5; mode "default"

bindsym $mod+Shift+h move container to workspace 1; workspace 1; mode "default"
bindsym $mod+Shift+j move container to workspace 2; workspace 2; mode "default"
bindsym $mod+Shift+k move container to workspace 3; workspace 3; mode "default"
bindsym $mod+Shift+l move container to workspace 4; workspace 4; mode "default"
bindsym $mod+Shift+semicolon move container to workspace 5; workspace 5; mode "default"

