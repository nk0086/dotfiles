[user]
	email = email
	name = nk0086
[alias]
	tree = log --pretty='format:%C(yellow)%h %C(white)%s %C(red)%d %C(green)[%ad] %C(cyan)<%an>' --date=relative -40 --graph
	st = status
	co = checkout
	br = branch
	cm = commit
	sw = switch
	logline = log --oneline
[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only --features=interactive

[delta "interactive"]
    keep-plus-minus-markers = false

[delta "decorations"]
    commit-decoration-style = blue ol
    commit-style = raw
    file-style = omit
    hunk-header-decoration-style = blue box
    hunk-header-file-style = red
    hunk-header-line-number-style = "#067a00"
    hunk-header-style = file line-number syntax

